# =============================================================================
# Network Security MLOps — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the .env file to Git.
# =============================================================================

# --- MongoDB ---
MONGO_DB_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=<appName>

# --- AWS ---
AWS_ACCESS_KEY_ID=<your-aws-access-key>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-key>
AWS_DEFAULT_REGION=us-east-1
BUCKET_NAME=networksecurity3
PREDICTION_BUCKET_NAME=network-security-prediction

# --- MLflow / Experiment Tracking ---
MLFLOW_TRACKING_URI=<your-mlflow-tracking-uri>
MLFLOW_TRACKING_USERNAME=<your-mlflow-username>
MLFLOW_TRACKING_PASSWORD=<your-mlflow-password>

# --- Docker / ECR (used by CI pipeline) ---
AWS_ACCOUNT_ID=<your-aws-account-id>
ECR_REPOSITORY=network-security-mlops
IMAGE_TAG=latest
